# Cloudflare Pages cache headers & security headers

# Default headers for all routes
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# HTML pages — shorter cache TTL for freshness
/index.html
  Cache-Control: public, max-age=3600, must-revalidate
  Content-Type: text/html; charset=utf-8

/*.html
  Cache-Control: public, max-age=1800, must-revalidate
  Content-Type: text/html; charset=utf-8

# Sitemap & robots — moderate cache
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

# Static assets — long cache TTL (1 year)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts — very long cache
/assets/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Font-Display: swap
